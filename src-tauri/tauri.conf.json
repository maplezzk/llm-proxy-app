{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "llm-proxy-app",
  "version": "0.1.0",
  "identifier": "com.maplezzk.llm-proxy-app",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/llm-proxy"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
